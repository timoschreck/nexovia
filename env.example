# Beispiel-Konfigurationsdatei für die Nexovia-Anwendung
# Kopiere diese Datei zu `.env` und ersetze die Platzhalter durch deine echten Werte.

# Geheimnis für die Admin-Oberfläche
ADMIN_TOKEN=secret

# SMTP-Einstellungen für den Versand von E-Mails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dein_smtp_benutzer
SMTP_PASS=dein_smtp_passwort
SMTP_FROM=absender@example.com
ADMIN_EMAIL=admin@example.com

# Google reCAPTCHA Secret (Server-Seite)
RECAPTCHA_SECRET=dein_recaptcha_secret

# Google Analytics 4 Measurement ID
GA_MEASUREMENT_ID=G-2P76BF4SQW

# Meta Pixel ID
FB_PIXEL_ID=XXXXXXXXXX